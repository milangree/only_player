<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.OnlyPlayer.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>
        <item name="windowSplashScreenBackground">#F7F6FB</item>
        <item name="android:windowSplashScreenBackground">#F7F6FB</item>
        <item name="android:statusBarColor">#F7F6FB</item>
        <item name="android:navigationBarColor">#F7F6FB</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="postSplashScreenTheme">@style/Theme.OnlyPlayer</item>
    </style>

    <style name="Theme.OnlyPlayer.Splash.Light" parent="Theme.OnlyPlayer.Splash">
        <item name="windowSplashScreenBackground">#F7F6FB</item>
        <item name="android:windowSplashScreenBackground">#F7F6FB</item>
        <item name="android:statusBarColor">#F7F6FB</item>
        <item name="android:navigationBarColor">#F7F6FB</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.OnlyPlayer.Splash.Dark" parent="Theme.OnlyPlayer.Splash">
        <item name="windowSplashScreenBackground">#171B1C</item>
        <item name="android:windowSplashScreenBackground">#171B1C</item>
        <item name="android:statusBarColor">#171B1C</item>
        <item name="android:navigationBarColor">#171B1C</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.OnlyPlayer" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar" />
</resources>
